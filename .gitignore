# datasets - too large for git
ml/data/raw/
ml/data/processed/
ml/data/splits/

# trained model binaries - download from Colab/Kaggle after training
ml/exported_models/*.onnx
ml/exported_models/*.pkl
ml/exported_models/*.onnx.data
# exception: keep dummy stub marker
!ml/exported_models/.gitkeep

# test/scratch ONNX stubs
ml/exported_models/_test*.onnx
ml/exported_models/_test*.onnx.data

# mlflow artifacts
ml/mlruns/
ml/mlartifacts/

# notebook checkpoints
ml/notebooks/.ipynb_checkpoints/
**/.ipynb_checkpoints/

# python
__pycache__/
*.pyc
*.pyo
.env
.venv/
venv/
*.egg-info/

# docker / logs
*.log

# OS
.DS_Store
Thumbs.db
*.lnk

# IDE
.vscode/
.idea/
